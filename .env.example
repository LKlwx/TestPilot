# TestPilot 环境变量配置模板
# 复制此文件为 .env 后，run.py 会自动加载（通过 python-dotenv）
# cp .env.example .env

# ===== 核心密钥配置 (生产环境必填) =====
# Flask 会话密钥，用于加密 Session 数据
# 生产环境必须使用强随机字符串，例如: openssl rand -base64 32
SECRET_KEY=your-strong-secret-key-here-min-32-chars

# JWT 签名密钥，用于生成和验证 Token
# 生产环境必须使用强随机字符串。如果未设置或为默认值，应用将拒绝启动
JWT_SECRET_KEY=your-strong-jwt-secret-key-here-min-32-chars

# ===== 运行环境配置 =====
# 运行环境: development, test, demo, production
# 也可以通过启动命令传入，如: FLASK_ENV=production python run.py
FLASK_ENV=development

# ===== AI 模型配置 (可选) =====
# LM Studio 或其它本地大模型服务地址
AI_API_BASE=http://127.0.0.1:1234

# 使用的模型名称
AI_MODEL=qwen3.5-9b

# ===== 数据库配置 (可选，默认使用 SQLite) =====
# 默认 SQLite 数据库文件位于 instance/testpilot.db
# 如需切换 PostgreSQL/MySQL 请取消注释并修改
# SQLALCHEMY_DATABASE_URI=postgresql://user:password@localhost/testpilot

# ===== Celery & Redis 配置 (可选) =====
# Redis 连接地址：Docker 环境用 redis://redis:6379/0，本地开发用 localhost
REDIS_URL=redis://localhost:6379/0

# ===== 性能测试配置 (可选) =====
# 压测明细数据保留天数（超期自动清理，不影响汇总报告）
PERF_DETAIL_RETENTION_DAYS=30
